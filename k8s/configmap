apiVersion: v1
kind: ConfigMap
metadata:
  name: aws-auth
  namespace: kube-system
data:
  mapRoles: |
    - rolearn: arn:aws:iam::867637277744:role/AWS_AKS_CLUSTER-node-group-role
      groups:
      - system:bootstrappers
      - system:nodes
      username: system:node:{{EC2PrivateDNSName}}
  mapUsers: |
    - userarn: arn:aws:iam::867637277744:user/dinanshu
      username: dinanshu
      groups:
      - system:masters
    - userarn: arn:aws:iam::867637277744:user/aditya-narayan.singh@socgen.com
      username: aditya-narayan.singh@socgen.com
      groups:
      - system:masters
